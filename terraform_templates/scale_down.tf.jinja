# ── AUTO-GENERATED BY SRE FinOps Orchestrator ─────────────────────────────
# Instance: {{ instance_id }}
# Reason  : {{ reason }}
# CPU avg : {{ avg_cpu }}% over {{ lookback_days }} days
# Cost    : ${{ monthly_cost }}/month
# PR      : {{ pr_url }}
# Generated: {{ timestamp }}
# ─────────────────────────────────────────────────────────────────────────────
# REVIEW REQUIRED: Merge this PR to approve scale-down.
# No terraform apply runs automatically.
# ─────────────────────────────────────────────────────────────────────────────

resource "aws_instance" "{{ resource_name }}" {
  ami           = "{{ ami_id }}"
  instance_type = "{{ instance_type }}"

  # Scaled to 0 by SRE FinOps Orchestrator — pending human approval
  count = 0

  tags = {
    Name                = "{{ name_tag }}"
    ManagedBy           = "terraform"
    SRERemediation      = "true"
    SRERemediationDate  = "{{ timestamp }}"
    SRERemediationReason = "Underutilized: {{ avg_cpu }}% CPU, ${{ monthly_cost }}/mo"
  }
}
