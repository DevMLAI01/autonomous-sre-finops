# ── LLM ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# ── LangSmith Observability ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=autonomous-sre-finops

# ── AWS (Read-Only IAM credentials) ──────────────────────────────────
AWS_ACCESS_KEY_ID=your_readonly_access_key
AWS_SECRET_ACCESS_KEY=your_readonly_secret_key
AWS_DEFAULT_REGION=us-east-1

# ── GitHub ────────────────────────────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO_OWNER=your_org_or_username
GITHUB_REPO_NAME=your_terraform_repo

# ── Qdrant Vector DB ──────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=sre_docs

# ── Thresholds ────────────────────────────────────────────────────────
CPU_UTILIZATION_THRESHOLD=5.0       # % — flag resources below this
MONTHLY_COST_THRESHOLD=100.0        # USD — flag resources above this
LOOKBACK_DAYS=7

# ── Notifications (mockup) ────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
NOTIFICATION_EMAIL=sre-team@yourcompany.com
